FROM python:3.11-slim

WORKDIR /app

# تثبيت المكتبات الأساسية (مهم جداً لـ FAISS و الـ PDF Processing)
RUN apt-get update && apt-get install -y \
    build-essential \
    libxml2-dev \
    libxslt-dev \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# نسخ الـ requirements (تأكدي إنه بره في الـ security_node جنب الدوكر فايل)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# نسخ كل ملفات المشروع
COPY . .

# تظبيط الـ Path عشان يشوف فولدر scanner والملفات التانية
ENV PYTHONPATH="${PYTHONPATH}:/app:/app/scanner"

EXPOSE 8000

# التصحيح: تشغيل api.py اللي موجود بره مباشرة
CMD ["python", "api.py", "--host=0.0.0.0", "--port=5000"]