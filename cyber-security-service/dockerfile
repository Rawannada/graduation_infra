FROM python:3.11-slim

WORKDIR /app

# تثبيت مكتبات النظام
RUN apt-get update && apt-get install -y \
    build-essential \
    libxml2-dev \
    libxslt-dev \
    && rm -rf /var/lib/apt/lists/*

# نسخ الـ requirements وتثبيتها
COPY scanner/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# نسخ كل الملفات
COPY . .

# تعريف مسار البايثون
ENV PYTHONPATH="${PYTHONPATH}:/app/scanner"

EXPOSE 5000

# التعديل السحري هنا: بنجبر الفلاسك يشتغل على 0.0.0.0 عشان يشوف الـ Node
CMD ["python", "scanner/api.py", "--host=0.0.0.0"]