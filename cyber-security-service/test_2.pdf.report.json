from flask import Flask, request, jsonify
import os
import tempfile
import sys

# Pipeline بتاعك الـ600 سطر
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from pipeline import run as run_pipeline

app = Flask(__name__)
app.config['MAX_CONTENT_LENGTH'] = 20 * 1024 * 1024  # 20MB

@app.route('/scan', methods=['POST'])
def scan_file():
    """Full pipeline JSON للـSOC"""
    if 'file' not in request.files:
        return jsonify({"error": "No file"}), 400
    file = request.files['file']
    if not file.filename:
        return jsonify({"error": "No filename"}), 400
    
    with tempfile.NamedTemporaryFile(delete=False, suffix='.pdf') as tmp:
        filepath = tmp.name
        file.save(filepath)
    
    result = run_pipeline(filepath)
    os.unlink(filepath)
    return jsonify(result.to_dict())

@app.route('/quick-scan', methods=['POST'])
def quick_scan():
    """Gate report مختصر (hash + triggers)"""
    file = request.files['file']
    with tempfile.NamedTemporaryFile(delete=False) as tmp:
        filepath = tmp.name
        file.save(filepath)
    
    result = run_pipeline(filepath)
    os.unlink(filepath)
    gate_report = result.step2_gate_report
    gate_report['file_name'] = os.path.basename(file.filename)
    gate_report['created_at'] = result.processed_at
    return jsonify(gate_report)

@app.route('/user-report', methods=['POST'])
def user_friendly_report():
    """User-friendly JSON (English)"""
    file = request.files['file']
    with tempfile.NamedTemporaryFile(delete=False) as tmp:
        filepath = tmp.name
        file.save(filepath)
    
    result = run_pipeline(filepath)
    os.unlink(filepath)
    
    return jsonify({
        "status": "✅ SAFE" if result.safe else "🚫 BLOCKED",
        "score": f"{result.security_score.score}/100",
        "ai_text": result.clean_text[:1000] + "..." if result.clean_text else "Text extraction failed",
        "issues": [t['type'] for t in result.step2_gate_report.get("triggers", [])],
        "summary": result.summary,
        "warnings": result.step3_error or "None",
        "needs_review": result.security_score.score < 80
    })

@app.route('/health', methods=['GET'])
def health():
    return jsonify({"status": "OK", "version": "v2.0"})

if __name__ == '__main__':
    app.run(debug=True, host='0.0.0.0', port=5000)
